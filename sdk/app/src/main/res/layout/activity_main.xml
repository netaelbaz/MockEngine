<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Calls"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HTTP Response Interception Testing"
            android:textSize="16sp"
            android:textColor="#757575"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- Card 1: GET /demo/users -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GET"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#4CAF50"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="/demo/users"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRun1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▷  RUN"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="#6200EE" />

                <LinearLayout
                    android:id="@+id/logSection1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Response Log"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:paddingBottom="4dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#FAFAFA"
                        android:padding="8dp"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/tvLog1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#212121"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2: GET /demo/users/123 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GET"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#4CAF50"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="/demo/users/123"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRun2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▷  RUN"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="#6200EE" />

                <LinearLayout
                    android:id="@+id/logSection2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Response Log"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:paddingBottom="4dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#FAFAFA"
                        android:padding="8dp"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/tvLog2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#212121"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3: POST /demo/users -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POST"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#2196F3"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="/demo/users"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRun3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▷  RUN"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="#6200EE" />

                <LinearLayout
                    android:id="@+id/logSection3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Response Log"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:paddingBottom="4dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#FAFAFA"
                        android:padding="8dp"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/tvLog3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#212121"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MockEngine SDK v1.0 | Powered by FastAPI"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:paddingBottom="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
