<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MockEngine SDK Demo"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HTTP Response Interception Testing"
        android:textSize="16sp"
        android:textColor="#757575"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Test Button -->
    <Button
        android:id="@+id/btnTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Run Test API Calls"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#6200EE" />

    <!-- Log Container -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Request/Response Logs:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#424242"
        android:paddingBottom="4dp" />

    <!-- Log Display -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logs will appear here..."
            android:textSize="12sp"
            android:textColor="#212121"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <!-- Info Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MockEngine SDK v1.0 | Powered by FastAPI"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:paddingTop="8dp" />

</LinearLayout>